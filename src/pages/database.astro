---
import Layout from "../layouts/Page.astro";
import { Image } from "astro:assets";

import imgGits from "../assets/ghostshell.webp";
// Obras
const obras = [
    {
        titulo: "Akira",
        tipo: "Película",
        date: "1988",
        img: "https://m.media-amazon.com/images/I/61vhScYauTL._AC_SL1500_.jpg", // Reemplaza con tus rutas
        descripcion: "¿Poderes en Neo-Tokyo?",
    },
    {
        titulo: "Neuromante",
        tipo: "Libro",
        date: "1984",
        img: "https://m.media-amazon.com/images/I/811x3C8CHVL._SL1379_.jpg",
        descripcion: "La obra Magna del cyberpunk.",
    },
    {
        titulo: "Cyberpunk 2077",
        tipo: "Videojuego",
        date: "2020",
        img: "https://store-images.s-microsoft.com/image/apps.47379.63407868131364914.bcaa868c-407e-42c2-baeb-48a3c9f29b54.89bb995b-b066-4a53-9fe4-0260ce07e894",
        descripcion: "No hay finales felices en Night City.",
    },
    {
        titulo: "Ghost in the Shell",
        tipo: "Película",
        date: "1995",
        img: imgGits.src,
        descripcion: "¿Conciencia o programa?",
    },

    {
        titulo: "Blade Runner",
        tipo: "Película",
        date: "1982",
        img: "https://m.media-amazon.com/images/M/MV5BOWQ4YTBmNTQtMDYxMC00NGFjLTkwOGQtNzdhNmY1Nzc1MzUxXkEyXkFqcGc@._V1_.jpg",
        descripcion: "Más humano que los humanos.",
    },
    {
        titulo: "Blade Runner 2049",
        tipo: "Película",
        date: "2017",
        img: "https://m.media-amazon.com/images/M/MV5BNzA1Njg4NzYxOV5BMl5BanBnXkFtZTgwODk5NjU3MzI@._V1_FMjpg_UX1000_.jpg",
        descripcion: "You look like a good Joe.",
    },
    {
        titulo: "Cyberpunk: Edgerunners",
        tipo: "Serie",
        date: "2022",
        img: "https://moviepostermexico.com/cdn/shop/products/cyberpunk_edgerunners_xxlg_1024x1024@2x.jpg?v=1664234839",
        descripcion: "Lo siento, no podemos ir a la luna juntos.",
    },
    {
        titulo: "Matrix",
        tipo: "Película",
        date: "1999",
        img: "https://m.media-amazon.com/images/M/MV5BN2NmN2VhMTQtMDNiOS00NDlhLTliMjgtODE2ZTY0ODQyNDRhXkEyXkFqcGc@._V1_FMjpg_UX1000_.jpg",
        descripcion: "Estamos en una simulación.",
    },
    {
        titulo: "¿Sueñan los androides con ovejas eléctricas?",
        tipo: "Libro",
        date: "1968",
        img: "https://m.media-amazon.com/images/I/91heWmnaDeL._SL1500_.jpg",
        descripcion: "Es más cruda que la película.",
    },
];
// Ordenar antes de mapear
const obrasOrdenadas = obras.sort(
    (a, b) => parseInt(a.date) - parseInt(b.date),
);
---

<Layout title="DATABASE" description="Obras cyberpunk">
    <p>
        Aquí encontrarás diferentes obras cyberpunk. <br />
        Tal vez música, series, películas, etc. <br />
        La voy a estar actualizando.
    </p>

    <div class="galeria">
        {
            obras.map((obra) => {
                const tipoClase = obra.tipo
                    .toLowerCase()
                    .normalize("NFD")
                    .replace(/[\u0300-\u036f]/g, "");

                return (
                    <article class={`card ${tipoClase}`}>
                        <div class="date-badge">{obra.date}</div>
                        <img src={obra.img} alt={obra.titulo} />
                        <div class="info">
                            <div class="meta">
                                <span class="tipo-texto">{obra.tipo}</span>
                                <span class="divider">|</span>
                                <span class="date-text">{obra.date}</span>{" "}
                                {/* Esta es la fecha */}
                            </div>
                            <h3>{obra.titulo}</h3>
                            <p>{obra.descripcion}</p>
                        </div>
                    </article>
                );
            })
        }
    </div>
</Layout>

<style>
    .galeria {
        display: grid;
        /* Crea columnas automáticas de mínimo 250px */
        grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
        gap: 2rem;
        padding: 20px 0;
    }

    .card {
        background: #1a1a1a;
        border: 1px solid #333;
        border-radius: 8px;
        overflow: hidden;
        transition:
            transform 0.3s ease,
            border-color 0.3s ease;
    }

    .card:hover {
        transform: translateY(-5px);
        border-color: #00ff41; /* Verde neón muy cyberpunk */
    }

    .card img {
        width: 100%;
        height: 32rem;
        object-fit: cover;
        filter: contrast(150%);
    }

    .info {
        padding: 1.5rem;
    }

    .info span {
        font-size: 0.8rem;
        color: #00ff41;
        text-transform: uppercase;
        letter-spacing: 1px;
    }

    .info h3 {
        margin: 0.5rem 0;
        color: #fff;
    }

    .info p {
        font-size: 0.9rem;
        color: #ccc;
    }
    .meta {
        display: flex;
        align-items: center;
        font-size: 0.75rem;
        margin-bottom: 0.5rem;
    }

    .year {
        color: #888;
        font-weight: bold;
    }

    .divider {
        color: #444;
        margin: 0 5px;
    }

    .card {
        position: relative;
    }

    .date-badge {
        position: absolute;
        top: 10px;
        right: 10px;
        background: rgba(0, 0, 0, 0.8);
        color: #00ff41;
        padding: 2px 8px;
        font-size: 0.7rem;
        border: 1px solid #00ff41;
        border-radius: 4px;
        z-index: 10;
    }
    /* Color para Peliculas */
    .pelicula {
        border-color: #ff0055;
    }
    .pelicula:hover {
        box-shadow: 0 0 15px rgba(255, 0, 85, 0.4);
    }
    .pelicula .tipo-texto {
        color: #ff0055;
    }

    /* Color para Libros */
    .libro {
        border-color: #00d2ff;
    }
    .libro:hover {
        box-shadow: 0 0 15px rgba(0, 210, 255, 0.4);
    }
    .libro .tipo-texto {
        color: #00d2ff;
    }

    /* Color para Series  */
    .serie {
        border-color: #ffcc00;
    }
    .serie:hover {
        box-shadow: 0 0 15px rgba(255, 204, 0, 0.4);
    }
    .serie .tipo-texto {
        color: #ffcc00;
    }
    /* Color para Videojuegos  */
    .videojuego {
        border-color: #00ff04;
    }
    .videojuego:hover {
        box-shadow: 0 0 15px rgba(0, 255, 13, 0.4);
    }
    .videojuego .tipo-texto {
        color: #22ff00;
    }
</style>
