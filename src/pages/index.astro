---
import BaseHead from "../components/BaseHead.astro";
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";
import { SITE_DESCRIPTION, SITE_TITLE } from "../consts";
---

<!doctype html>
<html lang="es">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<h1 class="glitch" data-text="// Hanran">// Hanran</h1>
			<p>
				Bienvenida a Hanran. Un archivo dedicado a la cultura, estética
				y filosofía cyberpunk, construido desde una perspectiva del
				movimiento.
			</p>
			<p>
				Transmisiones irregulares. Sin algoritmos. Sin patrocinios. Solo
				yo y mi lap.
			</p>
		</main>
		<style>
			.glitch {
				position: relative;
				color: var(--accent);
				animation: shake 4s linear infinite;
			}
			h1 {
				animation: shake 6s linear infinite !important;
				border: 2px solid rgb(0, 251, 255);
			}
			.glitch::before,
			.glitch::after {
				content: attr(data-text);
				position: absolute;
				top: 0;
				left: 0;
				width: 100%;
				height: 100%;
				background: #0a0a14;
				overflow: hidden;
			}
			.glitch::after {
				color:  #4a59ffbf;
				left: 3px;
				text-shadow: -4px 0 #5362556c;
				animation: clip-2 5s infinite linear alternate-reverse;
			}
			@keyframes clip-1 {
				0% {
					clip: rect(10px, 9999px, 20px, 0);
				}
				5% {
					clip: rect(60px, 9999px, 80px, 0);
				}
				10% {
					clip: rect(5px, 9999px, 15px, 0);
				}
				15% {
					clip: rect(40px, 9999px, 55px, 0);
				}
				20% {
					clip: rect(80px, 9999px, 95px, 0);
				}
				25% {
					clip: rect(25px, 9999px, 35px, 0);
				}
				30% {
					clip: rect(70px, 9999px, 85px, 0);
				}
				35% {
					clip: rect(15px, 9999px, 30px, 0);
				}
				40% {
					clip: rect(50px, 9999px, 65px, 0);
				}
				45% {
					clip: rect(90px, 9999px, 100px, 0);
				}
				50% {
					clip: rect(30px, 9999px, 45px, 0);
				}
				100% {
					clip: rect(30px, 9999px, 45px, 0);
				}
			}
			@keyframes clip-2 {
				0% {
					clip: rect(50px, 9999px, 70px, 0);
				}
				5% {
					clip: rect(20px, 9999px, 35px, 0);
				}
				10% {
					clip: rect(75px, 9999px, 90px, 0);
				}
				15% {
					clip: rect(10px, 9999px, 25px, 0);
				}
				20% {
					clip: rect(45px, 9999px, 60px, 0);
				}
				25% {
					clip: rect(85px, 9999px, 95px, 0);
				}
				30% {
					clip: rect(35px, 9999px, 50px, 0);
				}
				35% {
					clip: rect(65px, 9999px, 80px, 0);
				}
				40% {
					clip: rect(5px, 9999px, 20px, 0);
				}
				45% {
					clip: rect(55px, 9999px, 70px, 0);
				}
				50% {
					clip: rect(25px, 9999px, 40px, 0);
				}
				100% {
					clip: rect(25px, 9999px, 40px, 0);
				}
			}
			@keyframes shake {
				0%,
				100% {
					transform: translate(0);
				}
				1% {
					transform: translate(-6px, 2px) skewX(-5deg);
				}
				1.5% {
					transform: scaleY(4) skewX(-80deg);
				}
				2% {
					transform: translate(0) scaleY(1) skewX(0deg);
				}
				2.5% {
					transform: translate(4px, -2px) skewX(3deg);
				}
				3% {
					transform: translate(0);
				}
				51% {
					transform: translate(0) scaleX(1) scaleY(1);
				}
				52% {
					transform: scaleX(2) scaleY(0.1) skewX(80deg);
				}
				52.5% {
					transform: translate(-4px, 0) scaleX(1.5) scaleY(0.3);
				}
				53% {
					transform: translate(0) scaleX(1) scaleY(1);
				}
			}
		</style>
		<Footer />
	</body>
</html>
