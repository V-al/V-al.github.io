---
import { SITE_TITLE } from '../consts';
---

<header>
	<nav>
		<h2><a href="/">{SITE_TITLE}</a></h2>
		<button class="menu-toggle" id="menuToggle" aria-label="Toggle menu">
			<span></span>
			<span></span>
			<span></span>
		</button>
		<div class="internal-links" id="navLinks">
			<a href="/">START</a>
			<a href="/blog">TRANSMISSIONS</a>
			<a href="/about">GHOST</a>
		</div>
		<div class="social-links">
			<a href="https://github.com/V-al" target="_blank" aria-label="GitHub">
				<svg viewBox="0 0 16 16" aria-hidden="true" width="28" height="28">
					<path fill="currentColor" d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.012 8.012 0 0 0 16 8c0-4.42-3.58-8-8-8z"/>
				</svg>
			</a>
			<a href="https://www.tiktok.com/@vaaal_aguil" target="_blank" aria-label="TikTok">
				<svg viewBox="0 0 24 24" aria-hidden="true" width="28" height="28">
					<path fill="currentColor" d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-2.88 2.5 2.89 2.89 0 0 1-2.89-2.89 2.89 2.89 0 0 1 2.89-2.89c.28 0 .54.04.79.1V9.01a6.33 6.33 0 0 0-.79-.05 6.34 6.34 0 0 0-6.34 6.34 6.34 6.34 0 0 0 6.34 6.34 6.34 6.34 0 0 0 6.33-6.34V8.69a8.18 8.18 0 0 0 4.78 1.52V6.75a4.85 4.85 0 0 1-1.01-.06z"/>
				</svg>
			</a>
		</div>
	</nav>
</header>

<style>
	header {
		margin: 0;
		padding: 0 1em;
		background: #0a0a14;
		box-shadow: 0 2px 8px rgba(0, 255, 240, 15%);
		position: sticky;
		top: 0;
		z-index: 100;
	}
	h2 {
		margin: 0;
		font-size: 1em;
	}
	h2 a {
		text-decoration: none;
		color: #00fff0;
		letter-spacing: 2px;
	}
	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		height: 60px;
	}
	.internal-links a {
		padding: 0.5em;
		color: #00fff0;
		border-bottom: 2px solid transparent;
		text-decoration: none;
		letter-spacing: 2px;
		font-size: 0.85em;
		transition: border-color 0.2s;
	}
	.internal-links a:hover,
	.internal-links a.active {
		border-bottom-color: #00fff0;
	}
	.social-links {
		display: flex;
		gap: 0.5em;
		align-items: center;
	}
	.social-links a {
		color: #00fff0;
		display: flex;
		transition: opacity 0.2s;
	}
	.social-links a:hover {
		opacity: 0.7;
	}
	.menu-toggle {
		display: none;
		flex-direction: column;
		gap: 5px;
		background: none;
		border: none;
		cursor: pointer;
		padding: 0.5em;
	}
	.menu-toggle span {
		display: block;
		width: 25px;
		height: 2px;
		background: #00fff0;
		transition: all 0.3s;
	}

	@media (orientation: portrait) {
		.menu-toggle {
			display: flex;
		}
		.internal-links {
			display: none;
			position: absolute;
			top: 60px;
			left: 0;
			right: 0;
			background: #0a0a14;
			flex-direction: column;
			padding: 1em;
			gap: 1em;
			border-bottom: 1px solid #00fff0;
		}
		.internal-links.open {
			display: flex;
		}
		.social-links {
			display: flex;
		}
	}
</style>

<script>
	const toggle = document.getElementById('menuToggle');
	const links = document.getElementById('navLinks');
	toggle?.addEventListener('click', () => {
		links?.classList.toggle('open');
	});
</script>